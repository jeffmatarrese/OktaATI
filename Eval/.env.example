# Azure OpenAI / Foundry endpoint configuration
# Copy this file to .env and fill in your values.

# Example endpoint: https://my-foundry-resource.openai.azure.com/
AZURE_OPENAI_ENDPOINT=

# Your Azure OpenAI key (from the Foundry / Azure portal)
AZURE_OPENAI_API_KEY=

# API version. 2024-10-21 is a stable GA version that supports chat completions
# with JSON mode. Adjust if your deployment requires a newer version.
AZURE_OPENAI_API_VERSION=2024-10-21

# The deployment name (NOT the model name) you chose when deploying in Foundry.
# These are the recommended models for this eval:
#   - Classifier (model under test): gpt-5.4-nano — newest small model, leaves
#     room for failure modes that the eval can surface
#   - Judge: gpt-5.4 — same architecture family, clearly more capable than nano
#     so its grades on the classifier are trustworthy
AZURE_OPENAI_CLASSIFIER_DEPLOYMENT=gpt-5.4-nano
AZURE_OPENAI_JUDGE_DEPLOYMENT=gpt-5.4
